# Weather Signature Service - Environment Variables
# Copy this file to .env and fill in your actual values

# =============================================================================
# REQUIRED: OpenWeatherMap API Key
# =============================================================================
# Get your free API key from: https://openweathermap.org/api
# Sign up for a free account, then go to Dashboard -> API Keys
OPENWEATHER_API_KEY=your_api_key_here

# =============================================================================
# OPTIONAL: Default City
# =============================================================================
# The city name for weather lookup (e.g., Beijing, Shanghai, Guangzhou)
# Supports any city name recognized by OpenWeatherMap
# If not set, defaults to "Beijing"
CITY=Beijing

# =============================================================================
# EdgeOne Pages KV Binding
# =============================================================================
# NOTE: This is NOT set in local .env file!
# WEATHER_KV is a KV namespace binding configured in the EdgeOne Pages console:
# 1. Go to EdgeOne Pages Console -> Your Project -> Settings -> KV Storage
# 2. Create a new KV namespace (e.g., "weather-cache")
# 3. Bind it to your project with the binding name "WEATHER_KV"
#
# The value below is just a placeholder for documentation:
# WEATHER_KV=bound_in_edgeone_console
